{
  "version": "0.2.0",
  "configurations": [

    {
      "name": "bot_polling",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/app.py",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONUNBUFFERED": "1",
        "PYTHONPATH": "${workspaceFolder}"
      },
      "console": "integratedTerminal"
    },

    {
      "name": "start_consumer",
      "type": "debugpy",
      "request": "launch",
      "module": "consumers.start_consumer",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONUNBUFFERED": "1",
        "PYTHONPATH": "${workspaceFolder}"
      },
      "console": "integratedTerminal"
    },

    {
      "name": "reservation_consumer",
      "type": "debugpy",
      "request": "launch",
      "module": "consumers.reservation_consumer",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONUNBUFFERED": "1",
        "PYTHONPATH": "${workspaceFolder}"
      },
      "console": "integratedTerminal"
    },

    {
      "name": "application_form_consumer",
      "type": "debugpy",
      "request": "launch",
      "module": "consumers.application_form_consumer",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONUNBUFFERED": "1",
        "PYTHONPATH": "${workspaceFolder}"
      },
      "console": "integratedTerminal"
    },

    {
      "name": "uvicorn",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "src.app:create_app",
        "--factory",
        "--port",
        "8001"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONUNBUFFERED": "1",
        "PYTHONPATH": "${workspaceFolder}"
      },
      "console": "integratedTerminal"
    },

    {
      "name": "add_rooms",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/add_rooms.py",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONUNBUFFERED": "1",
        "PYTHONPATH": "${workspaceFolder}"
      },
      "console": "integratedTerminal"
    },

    {
      "name": "add_test_reservations",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/add_test_data/add_test_reservations.py",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONUNBUFFERED": "1",
        "PYTHONPATH": "${workspaceFolder}"
      },
      "console": "integratedTerminal"
    },

    {
      "name": "give_user_admin_role",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/give_user_admin_role.py",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONUNBUFFERED": "1",
        "PYTHONPATH": "${workspaceFolder}"
      },
      "console": "integratedTerminal"
    },

    {
      "name": "migrate",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/migrate.py",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONUNBUFFERED": "1",
        "PYTHONPATH": "${workspaceFolder}"
      },
      "console": "integratedTerminal"
    }
  ]
}
